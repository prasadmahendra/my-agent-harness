# my-agent-harness/smoke/.env.smoke.example
#
# Copy to a real .env.smoke (gitignored). tools/smoke.py auto-discovers
# smoke/.env.smoke and mounts it into the backend container as its env_file,
# so the backend boots with your real runtime config / creds without you
# exporting env vars on every run.
#
#     cp smoke/.env.smoke.example smoke/.env.smoke
#     $EDITOR smoke/.env.smoke
#
# NOTE: the compose file's own `environment:` keys OVERRIDE same-named keys
# here (they are generic passthroughs like DB_ENABLE_LOCAL_ON_DISK).

# ---------------------------------------------------------------------------
# Repo path overrides (optional) — RECOMMENDED way to set machine-local paths
# ---------------------------------------------------------------------------
# tools/harness_repos.py AUTO-LOADS this file at import time (process env wins
# over values here). Prefer setting paths HERE over shell exports: the agent
# runtime's shell does not inherit fresh exports from your launching shell, so
# exported vars may silently never reach the orchestrator. The var names come
# from each repo's `path_env` (default HARNESS_<KEY>_DIR).
#
# HARNESS_REPOS_ROOT=/path/to/your/repos-parent-dir
# HARNESS_BACKEND_DIR=/path/to/backend
# HARNESS_FRONTEND_DIR=/path/to/frontend
# HARNESS_INFRA_DIR=/path/to/infra
#
# Where this harness checkout lives (so the orchestrator can find tools/):
# HARNESS_DIR=/path/to/my-agent-harness

# ---------------------------------------------------------------------------
# DB backend for smoke (optional passthrough)
# ---------------------------------------------------------------------------
# sqlite (default) — backend uses local on-disk storage, no cloud needed.
# aurora           — real cloud DB; host needs VPN + a valid SSO session.
SMOKE_DB=sqlite

# ---------------------------------------------------------------------------
# Backend runtime env — everything app-specific goes here
# ---------------------------------------------------------------------------
# These are examples; replace with what YOUR backend reads at boot. This file
# is mounted verbatim as the backend container's env_file.
#
# ENV=dev
# LOGLEVEL=INFO
# SERVICE_NAME=my-service
# ANTHROPIC_API_KEY=
# AWS_PROFILE=
#
# Disable tracing in smoke unless you want it:
# DD_TRACE_ENABLED=false
